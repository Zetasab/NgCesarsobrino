  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:gh-pages": "ng build --configuration production --base-href /$npm_package_name/",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy:gh-pages": "npm run build:gh-pages"
  },
  "prettier": {

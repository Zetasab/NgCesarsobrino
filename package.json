    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@omnedia/ngx-aurora": "^4.0.1",
    "@omnedia/ngx-connection-beam": "^4.0.1",
    "@omnedia/ngx-flickering-grid": "^4.0.1",
    "@omnedia/ngx-galaxy": "^4.0.1",
    "@omnedia/ngx-marquee": "^4.0.1",
    "@omnedia/ngx-theme-toggle": "^4.0.1",
